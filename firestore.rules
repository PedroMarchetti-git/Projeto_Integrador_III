rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // A coleção 'users' (ou 'players') armazena dados específicos do usuário.
    // O usuário só pode ler/escrever no seu próprio documento.
    match /players/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Para outras coleções que não são diretamente ligadas ao usuário,
    // você precisará definir regras específicas.
    // Exemplo: Dados públicos que qualquer um pode ler
    // match /publicData/{documentId} {
    //   allow read: if true;
    //   allow write: if false; // Ninguém pode escrever em dados públicos.
    // }
  }
}
